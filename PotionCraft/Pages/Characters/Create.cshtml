@page
@model PotionCraft.Pages.Characters.CreateModel
@{
    ViewData["Title"] = "Создать персонажа";
}

<div class="container mt-4">
    <h2>Создать нового персонажа</h2>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <form method="post">
                <div class="mb-3">
                    <label asp-for="Name" class="form-label">Имя персонажа</label>
                    <input asp-for="Name" class="form-control" placeholder="Введите имя..." />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Intelligence" class="form-label">Интеллект</label>
                    <input asp-for="Intelligence" class="form-control" type="number" min="0" max="100" />
                    <span asp-validation-for="Intelligence" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Wisdom" class="form-label">Мудрость</label>
                    <input asp-for="Wisdom" class="form-control" type="number" min="0" max="100" />
                    <span asp-validation-for="Wisdom" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ProficiencyBonus" class="form-label">Бонус мастерства</label>
                    <input asp-for="ProficiencyBonus" class="form-control" type="number" min="2" max="6" />
                    <span asp-validation-for="ProficiencyBonus" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label d-block">Набор травника</label>
                    <div class="btn-group" role="group">
                        <input type="radio" class="btn-check" asp-for="HerbalismProficiencyLevel" value="0" id="herbNone" autocomplete="off" checked>
                        <label class="btn btn-outline-secondary" for="herbNone">Нет</label>

                        <input type="radio" class="btn-check" asp-for="HerbalismProficiencyLevel" value="1" id="herbProf" autocomplete="off">
                        <label class="btn btn-outline-secondary" for="herbProf">Владение</label>

                        <input type="radio" class="btn-check" asp-for="HerbalismProficiencyLevel" value="2" id="herbExp" autocomplete="off">
                        <label class="btn btn-outline-secondary" for="herbExp">Мастерство</label>
                    </div>
                    <div class="mt-2">
                        <label asp-for="HerbalismToolModifier" class="form-label">Модификатор инструмента</label>
                        <input asp-for="HerbalismToolModifier" class="form-control" type="number" min="-3" max="3" />
                        <span asp-validation-for="HerbalismToolModifier" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label d-block">Инструменты алхимика</label>
                    <div class="btn-group" role="group">
                        <input type="radio" class="btn-check" asp-for="AlchemistProficiencyLevel" value="0" id="alchNone" autocomplete="off" checked>
                        <label class="btn btn-outline-secondary" for="alchNone">Нет</label>

                        <input type="radio" class="btn-check" asp-for="AlchemistProficiencyLevel" value="1" id="alchProf" autocomplete="off">
                        <label class="btn btn-outline-secondary" for="alchProf">Владение</label>

                        <input type="radio" class="btn-check" asp-for="AlchemistProficiencyLevel" value="2" id="alchExp" autocomplete="off">
                        <label class="btn btn-outline-secondary" for="alchExp">Мастерство</label>
                    </div>
                    <div class="mt-2">
                        <label asp-for="AlchemistToolModifier" class="form-label">Модификатор инструмента</label>
                        <input asp-for="AlchemistToolModifier" class="form-control" type="number" min="-3" max="3" />
                        <span asp-validation-for="AlchemistToolModifier" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label d-block">Инструменты отравителя</label>
                    <div class="btn-group" role="group">
                        <input type="radio" class="btn-check" asp-for="PoisonerProficiencyLevel" value="0" id="poisNone" autocomplete="off" checked>
                        <label class="btn btn-outline-secondary" for="poisNone">Нет</label>

                        <input type="radio" class="btn-check" asp-for="PoisonerProficiencyLevel" value="1" id="poisProf" autocomplete="off">
                        <label class="btn btn-outline-secondary" for="poisProf">Владение</label>

                        <input type="radio" class="btn-check" asp-for="PoisonerProficiencyLevel" value="2" id="poisExp" autocomplete="off">
                        <label class="btn btn-outline-secondary" for="poisExp">Мастерство</label>
                    </div>
                    <div class="mt-2">
                        <label asp-for="PoisonerToolModifier" class="form-label">Модификатор инструмента</label>
                        <input asp-for="PoisonerToolModifier" class="form-control" type="number" min="-3" max="3" />
                        <span asp-validation-for="PoisonerToolModifier" class="text-danger"></span>
                    </div>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-success">Создать</button>
                    <a asp-page="/Index" class="btn btn-secondary ms-2">Отмена</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
