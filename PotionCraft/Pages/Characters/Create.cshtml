@page
@model PotionCraft.Pages.Characters.CreateModel
@{
    ViewData["Title"] = "—оздать персонажа";
}

<div class="container mt-4">
    <h2>—оздать нового персонажа</h2>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <form method="post">
                <div class="mb-3">
                    <label asp-for="Name" class="form-label">»м€ персонажа</label>
                    <input asp-for="Name" class="form-control" placeholder="¬ведите им€..." />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Intelligence" class="form-label">»нтеллект</label>
                    <input asp-for="Intelligence" class="form-control" type="number" min="0" max="100" />
                    <span asp-validation-for="Intelligence" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Wisdom" class="form-label">ћудрость</label>
                    <input asp-for="Wisdom" class="form-control" type="number" min="0" max="100" />
                    <span asp-validation-for="Wisdom" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ProficiencyBonus" class="form-label">Ѕонус мастерства</label>
                    <input asp-for="ProficiencyBonus" class="form-control" type="number" min="2" max="6" />
                    <span asp-validation-for="ProficiencyBonus" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label d-block">Ќабор травника</label>
                    <div class="btn-group" role="group">
                        <input type="radio" class="btn-check" asp-for="HerbalismProficiencyLevel" value="0" id="herbNone" autocomplete="off" checked>
                        <label class="btn btn-outline-secondary" for="herbNone">Ќет</label>

                        <input type="radio" class="btn-check" asp-for="HerbalismProficiencyLevel" value="1" id="herbProf" autocomplete="off">
                        <label class="btn btn-outline-secondary" for="herbProf">¬ладение</label>

                        <input type="radio" class="btn-check" asp-for="HerbalismProficiencyLevel" value="2" id="herbExp" autocomplete="off">
                        <label class="btn btn-outline-secondary" for="herbExp">ћастерство</label>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label d-block">»нструменты алхимика</label>
                    <div class="btn-group" role="group">
                        <input type="radio" class="btn-check" asp-for="AlchemistProficiencyLevel" value="0" id="alchNone" autocomplete="off" checked>
                        <label class="btn btn-outline-secondary" for="alchNone">Ќет</label>

                        <input type="radio" class="btn-check" asp-for="AlchemistProficiencyLevel" value="1" id="alchProf" autocomplete="off">
                        <label class="btn btn-outline-secondary" for="alchProf">¬ладение</label>

                        <input type="radio" class="btn-check" asp-for="AlchemistProficiencyLevel" value="2" id="alchExp" autocomplete="off">
                        <label class="btn btn-outline-secondary" for="alchExp">ћастерство</label>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label d-block">»нструменты отравител€</label>
                    <div class="btn-group" role="group">
                        <input type="radio" class="btn-check" asp-for="PoisonerProficiencyLevel" value="0" id="poisNone" autocomplete="off" checked>
                        <label class="btn btn-outline-secondary" for="poisNone">Ќет</label>

                        <input type="radio" class="btn-check" asp-for="PoisonerProficiencyLevel" value="1" id="poisProf" autocomplete="off">
                        <label class="btn btn-outline-secondary" for="poisProf">¬ладение</label>

                        <input type="radio" class="btn-check" asp-for="PoisonerProficiencyLevel" value="2" id="poisExp" autocomplete="off">
                        <label class="btn btn-outline-secondary" for="poisExp">ћастерство</label>
                    </div>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-success">—оздать</button>
                    <a asp-page="/Index" class="btn btn-secondary ms-2">ќтмена</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
