@page
@model PotionCraft.Pages.Characters.SelectModel
@{
    ViewData["Title"] = "Выбор персонажа";
}

<style>
    .character-available .card {
        border: 2px solid #28a745;
    }

    .character-available .btn-select {
        background-color: #28a745;
        color: #fff;
        border-color: #28a745;
    }

    .character-available .btn-select:hover {
        background-color: #218838;
        border-color: #1e7e34;
    }

    .character-taken .card {
        background-color: #e9ecef;
        border: 2px solid #adb5bd;
        color: #6c757d;
    }

    .character-taken .btn-select {
        background-color: #adb5bd;
        color: #fff;
        border-color: #adb5bd;
        pointer-events: none;
        cursor: not-allowed;
    }

    .character-yours .card {
        border: 2px solid #007bff;
    }

    .character-yours .card-title::after {
        content: " (Ваш)";
        font-size: 0.75rem;
        color: #007bff;
    }
</style>

<h1>Выбор персонажа</h1>

<div id="character-list" class="row mt-4">
    @foreach (var character in Model.Characters)
    {
        var isTaken = character.SelectedBy.HasValue;
        var wrapperClass = isTaken ? "character-taken" : "character-available";
        <div class="col-md-4 mb-3 @wrapperClass" id="character-card-@character.Id" data-id="@character.Id">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title text-primary">@character.Name</h5>
                    <p class="card-text">
                        <strong>Интеллект:</strong> @character.Intelligence<br />
                        <strong>Мудрость:</strong> @character.Wisdom<br />
                        <strong>Бонус мастерства:</strong> +@character.ProficiencyBonus<br />
                    </p>
                    <button class="btn btn-select w-100 mt-2"
                            onclick="selectCharacter('@character.Id')"
                            @(isTaken ? "disabled" : "")>
                        @(isTaken ? "Занят" : "Выбрать")
                    </button>
                </div>
            </div>
        </div>
    }
</div>

<div class="mt-4">
    <a asp-page="Create" class="btn btn-success">Создать нового персонажа</a>
</div>

<script>
    // Генерируем UUID игрока один раз на сессию браузера
    function getPlayerId() {
        let id = window.sessionStorage.getItem('player_session_id');
        if (!id) {
            id = crypto.randomUUID();
            window.sessionStorage.setItem('player_session_id', id);
        }
        return id;
    }

    async function selectCharacter(id) {
        const playerId = getPlayerId();
        try {
            const response = await fetch(`/api/characters/${id}/select`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ playerId })
            });
            if (response.ok) {
                const characterData = await response.json();
                window.sessionStorage.setItem('active_character', JSON.stringify(characterData));
                markAsYours(id);
                if (typeof updateActiveCharacterBadge === 'function') updateActiveCharacterBadge();
                showNotification('Персонаж успешно выбран!', 'success');
            } else if (response.status === 409) {
                alert('Этот персонаж только что был выбран другим игроком.');
                await refreshCharacterList();
            }
        } catch {
            alert('Ошибка при выборе персонажа. Попробуйте ещё раз.');
        }
    }

    function markAsYours(id) {
        // Снимаем предыдущую пометку "Ваш"
        document.querySelectorAll('.character-yours').forEach(el => {
            el.classList.remove('character-yours');
            el.classList.add('character-available');
            const btn = el.querySelector('.btn-select');
            if (btn) { btn.textContent = 'Выбрать'; btn.removeAttribute('disabled'); }
        });
        const card = document.getElementById(`character-card-${id}`);
        if (card) {
            card.classList.remove('character-available', 'character-taken');
            card.classList.add('character-yours');
            const btn = card.querySelector('.btn-select');
            if (btn) btn.textContent = 'Выбран';
        }
    }

    async function refreshCharacterList() {
        window.location.reload();
    }

    function showNotification(message, type) {
        const div = document.createElement('div');
        div.className = `alert alert-${type === 'success' ? 'success' : 'danger'} position-fixed`;
        div.style.cssText = 'top:1rem;right:1rem;z-index:9999;min-width:250px;';
        div.textContent = message;
        document.body.appendChild(div);
        setTimeout(() => div.remove(), 3000);
    }

    // Восстановить визуальное состояние из sessionStorage
    (function restoreSession() {
        const data = window.sessionStorage.getItem('active_character');
        if (data) {
            try {
                const character = JSON.parse(data);
                const charId = character.id || character.Id;
                const card = document.getElementById(`character-card-${charId}`);
                if (card) markAsYours(charId);
            } catch { /* игнорируем повреждённые данные */ }
        }
    })();

    // Освобождение персонажа при закрытии вкладки
    window.addEventListener('beforeunload', function () {
        const sessionData = window.sessionStorage.getItem('active_character');
        if (sessionData) {
            try {
                const character = JSON.parse(sessionData);
                const charId = character.id || character.Id;
                const playerId = getPlayerId();
                const blob = new Blob(
                    [JSON.stringify({ playerId })],
                    { type: 'application/json' }
                );
                navigator.sendBeacon(`/api/characters/${charId}/deselect`, blob);
            } catch { /* игнорируем */ }
        }
    });
</script>
