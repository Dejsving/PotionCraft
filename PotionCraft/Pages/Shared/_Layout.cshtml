<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PotionCraft</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PotionCraft.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">PotionCraft</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Characters/Select">Персонажи</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Gathering/Index">Сбор трав</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Herbs/Index">Травы</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/SourceAndIdea">Источник и идея</a>
                        </li>
                    </ul>
                    <span id="bag-icon" class="navbar-text ms-auto me-3" style="cursor: pointer; display: none;" title="Сумка">
                        <i class="bi bi-backpack2-fill fs-5"></i>
                    </span>
                    <span id="active-character-badge" class="navbar-text text-dark fw-semibold" style="cursor: pointer;" data-bs-toggle="popover" data-bs-placement="bottom" tabindex="0">
                        Персонаж не выбран
                    </span>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - PotionCraft - <a asp-area="" asp-page="/SourceAndIdea">Источник и идея</a>
        </div>
    </footer>

    <!-- Панель сумки -->
    <div class="offcanvas offcanvas-end" tabindex="-1" id="bagPanel" aria-labelledby="bagPanelLabel">
        <div class="offcanvas-header border-bottom">
            <h5 class="offcanvas-title" id="bagPanelLabel"><i class="bi bi-backpack2-fill me-2"></i>Сумка</h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Закрыть"></button>
        </div>
        <div class="offcanvas-body" id="bagPanelBody">
            <div class="text-center text-muted py-4">
                <div class="spinner-border spinner-border-sm" role="status"></div>
                <span class="ms-2">Загрузка...</span>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
    <script>
        let characterPopover = null;
        function updateActiveCharacterBadge() {
            const badge = document.getElementById('active-character-badge');
            if (!badge) return;
            try {
                const data = window.sessionStorage.getItem('active_character');
                if (data) {
                    const character = JSON.parse(data);
                    const name = character.name || character.Name;
                    
                    const intel = character.intelligence ?? character.Intelligence ?? 10;
                    const wis = character.wisdom ?? character.Wisdom ?? 10;
                    const prof = character.proficiencyBonus ?? character.ProficiencyBonus ?? 2;
                    const alch = character.alchemistModify ?? character.AlchemistModify ?? 0;
                    const herb = character.herbalismModify ?? character.HerbalismModify ?? 0;
                    const pois = character.poisonerModify ?? character.PoisonerModify ?? 0;

                    if (name) {
                        badge.textContent = '\u{1F464} ' + name;
                        badge.classList.add('text-primary');
                        badge.classList.remove('text-dark');
                        
                        const popoverContent = `
                            <div class="small">
                                <div><strong>Интеллект:</strong> ${intel}</div>
                                <div><strong>Мудрость:</strong> ${wis}</div>
                                <div><strong>Бонус мастерства:</strong> +${prof}</div>
                                <hr class="my-1"/>
                                <div><strong>Алхимия:</strong> ${(alch >= 0 ? '+' : '')}${alch}</div>
                                <div><strong>Травничество:</strong> ${(herb >= 0 ? '+' : '')}${herb}</div>
                                <div><strong>Отравитель:</strong> ${(pois >= 0 ? '+' : '')}${pois}</div>
                            </div>
                        `;
                        
                        badge.setAttribute('data-bs-content', popoverContent);
                        badge.setAttribute('data-bs-title', '<strong>Характеристики</strong>');
                        badge.setAttribute('data-bs-html', 'true');
                        badge.setAttribute('data-bs-trigger', 'focus');

                        if (characterPopover) {
                            characterPopover.dispose();
                        }
                        
                        characterPopover = new bootstrap.Popover(badge);
                        return;
                    }
                }
            } catch { /* игнорируем */ }
            badge.textContent = 'Персонаж не выбран';
            badge.classList.remove('text-primary');
            badge.classList.add('text-dark');
            badge.removeAttribute('data-bs-content');
            badge.removeAttribute('data-bs-title');
            if (characterPopover) {
                characterPopover.dispose();
                characterPopover = null;
            }
        }
        updateActiveCharacterBadge();

        // --- Сумка ---
        const rarityNames = { 0: 'Обычный', 1: 'Необычный', 2: 'Редкий', 3: 'Очень редкий' };
        const rarityColors = { 0: 'secondary', 1: 'success', 2: 'primary', 3: 'warning' };

        function updateBagIcon() {
            const bagIcon = document.getElementById('bag-icon');
            if (!bagIcon) return;
            const data = window.sessionStorage.getItem('active_character');
            if (data) {
                try {
                    const character = JSON.parse(data);
                    const id = character.id || character.Id;
                    if (id) {
                        bagIcon.style.display = '';
                        return;
                    }
                } catch { }
            }
            bagIcon.style.display = 'none';
        }

        function renderBagSection(title, icon, items, getItemName, getItemRarity) {
            if (!items || Object.keys(items).length === 0) {
                return `<h6 class="mt-3 mb-2"><i class="bi ${icon} me-1"></i>${title}</h6>
                        <p class="text-muted small ms-3">Пусто</p>`;
            }

            const grouped = {};
            for (const key in items) {
                const item = items[key];
                const rarity = getItemRarity(item);
                if (!grouped[rarity]) grouped[rarity] = [];
                grouped[rarity].push(item);
            }

            let html = `<h6 class="mt-3 mb-2"><i class="bi ${icon} me-1"></i>${title}</h6>`;
            const sortedRarities = Object.keys(grouped).map(Number).sort((a, b) => a - b);
            for (const rarity of sortedRarities) {
                const color = rarityColors[rarity] || 'secondary';
                html += `<div class="ms-2 mb-2">
                    <span class="badge bg-${color} mb-1">${rarityNames[rarity] || 'Неизвестно'}</span>
                    <ul class="list-group list-group-flush small">`;
                for (const item of grouped[rarity].sort((a, b) => getItemName(a).localeCompare(getItemName(b)))) {
                    html += `<li class="list-group-item d-flex justify-content-between align-items-center py-1 px-2">
                        ${getItemName(item)}
                        <span class="badge bg-dark rounded-pill">${item.quantity ?? item.Quantity ?? 0}</span>
                    </li>`;
                }
                html += `</ul></div>`;
            }
            return html;
        }

        async function loadBag() {
            const body = document.getElementById('bagPanelBody');
            if (!body) return;

            const data = window.sessionStorage.getItem('active_character');
            if (!data) {
                body.innerHTML = '<p class="text-muted text-center py-4">Персонаж не выбран</p>';
                return;
            }

            let characterId;
            try {
                const character = JSON.parse(data);
                characterId = character.id || character.Id;
            } catch {
                body.innerHTML = '<p class="text-danger text-center py-4">Ошибка данных персонажа</p>';
                return;
            }

            body.innerHTML = `<div class="text-center text-muted py-4">
                <div class="spinner-border spinner-border-sm" role="status"></div>
                <span class="ms-2">Загрузка...</span>
            </div>`;

            try {
                const response = await fetch(`/api/characters/${characterId}/bag`);
                if (!response.ok) throw new Error('Ошибка загрузки');

                const bag = await response.json();

                let html = '';
                html += renderBagSection('Травы', 'bi-flower1', bag.herbs || bag.Herbs,
                    item => (item.herb || item.Herb)?.name || (item.herb || item.Herb)?.Name || 'Неизвестная трава',
                    item => (item.herb || item.Herb)?.rarity ?? (item.herb || item.Herb)?.Rarity ?? 0
                );
                html += '<hr/>';
                html += renderBagSection('Зелья', 'bi-droplet-fill', bag.potions || bag.Potions,
                    item => (item.potion || item.Potion)?.name || (item.potion || item.Potion)?.Name || 'Неизвестное зелье',
                    item => (item.potion || item.Potion)?.recipe?.rarity ?? (item.potion || item.Potion)?.Recipe?.Rarity ?? 0
                );
                html += '<hr/>';
                html += renderBagSection('Яды', 'bi-exclamation-triangle-fill', bag.poisons || bag.Poisons,
                    item => (item.potion || item.Potion)?.name || (item.potion || item.Potion)?.Name || 'Неизвестный яд',
                    item => (item.potion || item.Potion)?.recipe?.rarity ?? (item.potion || item.Potion)?.Recipe?.Rarity ?? 0
                );

                body.innerHTML = html || '<p class="text-muted text-center py-4">Сумка пуста</p>';
            } catch (err) {
                body.innerHTML = `<p class="text-danger text-center py-4">Не удалось загрузить содержимое сумки</p>`;
            }
        }

        updateBagIcon();

        const bagIconEl = document.getElementById('bag-icon');
        if (bagIconEl) {
            bagIconEl.addEventListener('click', function () {
                const panel = new bootstrap.Offcanvas(document.getElementById('bagPanel'));
                loadBag();
                panel.show();
            });
        }
    </script>
</body>
</html>
