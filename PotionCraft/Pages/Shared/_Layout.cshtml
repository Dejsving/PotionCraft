<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PotionCraft</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PotionCraft.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">PotionCraft</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Characters/Select">Персонажи</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Gathering/Index">Сбор трав</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Herbs/Index">Травы</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/SourceAndIdea">Источник и идея</a>
                        </li>
                    </ul>
                    <span id="active-character-badge" class="navbar-text ms-auto text-dark fw-semibold" style="cursor: pointer;" data-bs-toggle="popover" data-bs-placement="bottom" tabindex="0">
                        Персонаж не выбран
                    </span>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - PotionCraft - <a asp-area="" asp-page="/SourceAndIdea">Источник и идея</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
    <script>
        let characterPopover = null;
        function updateActiveCharacterBadge() {
            const badge = document.getElementById('active-character-badge');
            if (!badge) return;
            try {
                const data = window.sessionStorage.getItem('active_character');
                if (data) {
                    const character = JSON.parse(data);
                    const name = character.name || character.Name;
                    
                    const intel = character.intelligence ?? character.Intelligence ?? 10;
                    const wis = character.wisdom ?? character.Wisdom ?? 10;
                    const prof = character.proficiencyBonus ?? character.ProficiencyBonus ?? 2;
                    const alch = character.alchemistModify ?? character.AlchemistModify ?? 0;
                    const herb = character.herbalismModify ?? character.HerbalismModify ?? 0;
                    const pois = character.poisonerModify ?? character.PoisonerModify ?? 0;

                    if (name) {
                        badge.textContent = '\u{1F464} ' + name;
                        badge.classList.add('text-primary');
                        badge.classList.remove('text-dark');
                        
                        const popoverContent = `
                            <div class="small">
                                <div><strong>Интеллект:</strong> ${intel}</div>
                                <div><strong>Мудрость:</strong> ${wis}</div>
                                <div><strong>Бонус мастерства:</strong> +${prof}</div>
                                <hr class="my-1"/>
                                <div><strong>Алхимия:</strong> ${(alch >= 0 ? '+' : '')}${alch}</div>
                                <div><strong>Травничество:</strong> ${(herb >= 0 ? '+' : '')}${herb}</div>
                                <div><strong>Отравитель:</strong> ${(pois >= 0 ? '+' : '')}${pois}</div>
                            </div>
                        `;
                        
                        badge.setAttribute('data-bs-content', popoverContent);
                        badge.setAttribute('data-bs-title', '<strong>Характеристики</strong>');
                        badge.setAttribute('data-bs-html', 'true');
                        badge.setAttribute('data-bs-trigger', 'focus');

                        if (characterPopover) {
                            characterPopover.dispose();
                        }
                        
                        characterPopover = new bootstrap.Popover(badge);
                        return;
                    }
                }
            } catch { /* игнорируем */ }
            badge.textContent = 'Персонаж не выбран';
            badge.classList.remove('text-primary');
            badge.classList.add('text-dark');
            badge.removeAttribute('data-bs-content');
            badge.removeAttribute('data-bs-title');
            if (characterPopover) {
                characterPopover.dispose();
                characterPopover = null;
            }
        }
        updateActiveCharacterBadge();
    </script>
</body>
</html>
