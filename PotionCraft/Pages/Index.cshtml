@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<div class="text-center">
    <h1 class="display-4">Добро пожаловать в PotionCraft</h1>
    <p class="lead">Система для автоматизации рутины при броске костей в игре DnD для дополнительных правил гербализма и алхимии.</p>
    
    <div class="row mt-5 justify-content-center">
        <div class="col-md-5 mb-3">
            <div class="card h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">Выбрать персонажа</h5>
                    <p class="card-text">Продолжите свое путешествие с уже созданным персонажем.</p>
                    <a asp-page="/Characters/Index" class="btn btn-primary mt-auto">Выбрать</a>
                </div>
            </div>
        </div>
        <div class="col-md-5 mb-3">
            <div class="card h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">Создать персонажа</h5>
                    <p class="card-text">Создайте нового персонажа для изучения гербализма и алхимии.</p>
                    <a asp-page="/Characters/Create" class="btn btn-success mt-auto">Создать</a>
                </div>
            </div>
        </div>
    </div>
</div>
