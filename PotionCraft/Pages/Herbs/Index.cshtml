@page
@using PotionCraft.Contracts.Enums
@using PotionCraft.Contracts.Extensions
@model PotionCraft.Pages.Herbs.IndexModel
@{
    ViewData["Title"] = "Список трав";

    string SortLink(string column)
    {
        bool isCurrentColumn = Model.SortBy == column;
        bool newDesc = isCurrentColumn && !Model.SortDesc;
        return Url.Page("/Herbs/Index", new
        {
            FilterName        = Model.FilterName,
            FilterDescription = Model.FilterDescription,
            FilterHerbType    = Model.FilterHerbType.HasValue ? (int?)Model.FilterHerbType : null,
            FilterRarity      = Model.FilterRarity.HasValue   ? (int?)Model.FilterRarity   : null,
            FilterEffect      = Model.FilterEffect,
            FilterDifficulty  = Model.FilterDifficulty,
            FilterHabitat     = Model.FilterHabitat.HasValue  ? (int?)Model.FilterHabitat  : null,
            SortBy   = column,
            SortDesc = newDesc
        }) ?? "#";
    }

    Func<string, string> SortIcon = column =>
    {
        if (Model.SortBy != column) return "";
        return Model.SortDesc ? " ▼" : " ▲";
    };
}

<h1>Список трав</h1>

<form method="get" class="mb-4">
    <div class="row g-2 align-items-end">
        <div class="col-md-2">
            <label class="form-label">Название</label>
            <input type="text" class="form-control" asp-for="FilterName" />
        </div>
        <div class="col-md-2">
            <label class="form-label">Описание</label>
            <input type="text" class="form-control" asp-for="FilterDescription" />
        </div>
        <div class="col-md-2">
            <label class="form-label">Тип</label>
            <select class="form-select" asp-for="FilterHerbType">
                <option value="">Все</option>
                @foreach (var val in Enum.GetValues<HerbTypeEnum>().Where(v => v != HerbTypeEnum.None))
                {
                    <option value="@((int)val)">@val.GetDisplayName()</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label">Редкость</label>
            <select class="form-select" asp-for="FilterRarity">
                <option value="">Все</option>
                @foreach (var val in Enum.GetValues<RarityEnum>())
                {
                    <option value="@((int)val)">@val.GetDisplayName()</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label">Эффект</label>
            <input type="text" class="form-control" asp-for="FilterEffect" />
        </div>
        <div class="col-md-1">
            <label class="form-label">Сложность</label>
            <input type="number" class="form-control" asp-for="FilterDifficulty" />
        </div>
        <div class="col-md-2">
            <label class="form-label">Среда обитания</label>
            <select class="form-select" asp-for="FilterHabitat">
                <option value="">Все</option>
                @foreach (var val in Enum.GetValues<TerrainEnum>())
                {
                    <option value="@((int)val)">@val.GetDisplayName()</option>
                }
            </select>
        </div>
        <div class="col-md-1 d-flex gap-1">
            <button type="submit" class="btn btn-primary">Найти</button>
            <a asp-page="/Herbs/Index" class="btn btn-outline-secondary">Сброс</a>
        </div>
    </div>
</form>

@if (Model.Herbs.Count == 0)
{
    <div class="alert alert-info">Травы не найдены.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th><a href="@(SortLink("Name"))" class="text-white text-decoration-none">Название@(SortIcon("Name"))</a></th>
                    <th><a href="@(SortLink("Description"))" class="text-white text-decoration-none">Описание@(SortIcon("Description"))</a></th>
                    <th><a href="@(SortLink("HerbType"))" class="text-white text-decoration-none">Тип@(SortIcon("HerbType"))</a></th>
                    <th><a href="@(SortLink("Rarity"))" class="text-white text-decoration-none">Редкость@(SortIcon("Rarity"))</a></th>
                    <th><a href="@(SortLink("Effect"))" class="text-white text-decoration-none">Эффект@(SortIcon("Effect"))</a></th>
                    <th><a href="@(SortLink("Difficulty"))" class="text-white text-decoration-none">Сложность@(SortIcon("Difficulty"))</a></th>
                    <th><a href="@(SortLink("Habitat"))" class="text-white text-decoration-none">Среда обитания@(SortIcon("Habitat"))</a></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var herb in Model.Herbs)
                {
                    <tr>
                        <td>@herb.Name</td>
                        <td>@herb.Description</td>
                        <td>
                            @{
                                var herbTypes = Enum.GetValues<HerbTypeEnum>()
                                    .Where(v => v != HerbTypeEnum.None && herb.HerbType.HasFlag(v))
                                    .Select(v => v.GetDisplayName());
                            }
                            @string.Join(", ", herbTypes)
                        </td>
                        <td>@herb.Rarity.GetDisplayName()</td>
                        <td>@herb.Effect</td>
                        <td>@herb.Difficulty</td>
                        <td>
                            @if (herb.Habitats.Any())
                            {
                                @string.Join(", ", herb.Habitats.Select(h => $"{h.Key.GetDisplayName()} ({h.Value})"))
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
